{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foxinthebox.ai/schemas/skillset.json",
  "title": "Skillset",
  "description": "Response schema for GET /skillset (contract v2.0)",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "contract_version": { "type": "string" },
    "data_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capabilities_declared": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["name", "version", "contract_version"]
}
